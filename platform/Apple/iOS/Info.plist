    <key>NSCalendarsUsageDescription</key>
    <string>WhatSon uses calendar and time information to organize work schedules.</string>

    <key>NSCalendarsFullAccessUsageDescription</key>
    <string>WhatSon needs full calendar access to create and update schedules.</string>

    <key>NSCalendarsWriteOnlyAccessUsageDescription</key>
    <string>WhatSon needs write access to add schedule events from notes.</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>WhatSon uses microphone access for voice notes and dictation.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>WhatSon uses photo access to attach images to notes and documents.</string>

    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>WhatSon saves exported visuals and attachments to your photo library.</string>

    <key>NSRemindersUsageDescription</key>
    <string>WhatSon uses reminders to capture tasks and deadlines from your workspace.</string>

    <key>NSRemindersFullAccessUsageDescription</key>
    <string>WhatSon needs full reminder access to create and update reminder items.</string>

    <key>NSRemindersWriteOnlyUsageDescription</key>
    <string>WhatSon needs write access to add reminders from created content.</string>

    <key>NSLocalNetworkUsageDescription</key>
    <string>WhatSon uses local network discovery to connect nearby services.</string>

    <key>NSBonjourServices</key>
    <array>
        <string>_whatson._tcp.</string>
    </array>

    <key>NSLocationWhenInUseUsageDescription</key>
    <string>WhatSon uses location while the app is active to personalize workspace context.</string>

    <key>NSBluetoothAlwaysUsageDescription</key>
